default_platform(:ios)

platform :ios do
  desc "Build a signed IPA"
  lane :package do
    export_method = ENV.fetch("EXPORT_METHOD", "app-store")
    profile_name = ENV["PROVISIONING_PROFILE_NAME"]
    match_type = case export_method
                 when "app-store" then "appstore"
                 when "ad-hoc" then "adhoc"
                 else export_method
                 end

    setup_ci if ENV["CI"]

    cocoapods(clean_install: true) if File.exist?("Podfile")

    if ENV["MATCH_GIT_URL"] && !ENV["MATCH_GIT_URL"].empty?
      match(
        type: match_type,
        readonly: true,
        app_identifier: "com.dxe.zfy",
        git_url: ENV["MATCH_GIT_URL"]
      )
    end

    if profile_name && !profile_name.empty?
      update_code_signing_settings(
        use_automatic_signing: false,
        path: "жЩЇжЬНдЇС.xcodeproj",
        team_id: ENV.fetch("DEVELOPMENT_TEAM", "VN2RMKL923"),
        profile_name: profile_name,
        code_sign_identity: "Apple Distribution"
      )
    end

    export_options = {
      teamID: ENV.fetch("DEVELOPMENT_TEAM", "VN2RMKL923")
    }
    if profile_name && !profile_name.empty?
      export_options[:provisioningProfiles] = {
        "com.dxe.zfy" => profile_name
      }
    end

    build_app(
      workspace: "жЩЇжЬНдЇС.xcworkspace",
      scheme: "жЩЇжЬНдЇС",
      configuration: "Release",
      clean: true,
      output_directory: "build",
      output_name: "жЩЇжЬНдЇС.ipa",
      export_method: export_method,
      export_options: export_options
    )
  end
end
